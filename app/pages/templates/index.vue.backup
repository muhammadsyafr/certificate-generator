          <!-- View toggle -->
          <div class="tpl-view-toggle">
            <button :class="['tpl-view-btn', { active: viewMode === 'grid' }]" @click="viewMode = 'grid'">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.9"/><rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.9"/><rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.9"/><rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.9"/></svg>
            </button>
            <button :class="['tpl-view-btn', { active: viewMode === 'list' }]" @click="viewMode = 'list'">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/></svg>
