          </button>
        </div>
      </div>

      <LoadingState v-if="pending" message="Loading templates..." />
      <ErrorState v-else-if="error" message="Failed to load templates" />

      <EmptyState
        v-else-if="!filteredTemplates || filteredTemplates.length === 0"
